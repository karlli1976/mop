{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mixed Ops Practice",
  "version": "0.1.0",
  "identifier": "com.example.mixedops",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mixed Ops Practice",
        "fullscreen": false,
        "resizable": true,
        "width": 1024,
        "height": 768
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
